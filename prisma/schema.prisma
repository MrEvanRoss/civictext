// CivicText - Full Database Schema
// Self-Service SMS/MMS Platform for Political & Municipal Organizations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum OrgStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  ARCHIVED
  DEACTIVATED
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  SENDER
  VIEWER
}

enum OptInStatus {
  OPTED_IN
  OPTED_OUT
  PENDING
  NEVER_OPTED_IN
}

enum CampaignType {
  BROADCAST
  P2P
  GOTV
  DRIP
  AUTO_REPLY
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  EXPANDING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  FAILED
  UNDELIVERED
  REJECTED
}


enum ConversationState {
  OPEN
  PENDING
  CLOSED
  ARCHIVED
  OPTED_OUT
}

enum BrandRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

enum CampaignRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

enum PhoneNumberStatus {
  ACTIVE
  RELEASED
  SUSPENDED
}

enum P2PAssignmentStatus {
  PENDING
  SENT
  SKIPPED
  REPLIED
  OPTED_OUT
}

enum SurveyType {
  MULTIPLE_CHOICE
  YES_NO
  OPEN_ENDED
  RATING
  NPS
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ContentFilterAction {
  HIDE
  FLAG
  AUTO_REPLY
  BLOCK
}

enum FlowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum FlowTrigger {
  KEYWORD
  TAG_ADDED
  LIST_JOINED
  CONTACT_CREATED
  MANUAL
}

enum FlowStepType {
  SEND_MESSAGE
  WAIT_DELAY
  ADD_TAG
  REMOVE_TAG
  ADD_TO_LIST
  REMOVE_FROM_LIST
  BRANCH_CONDITION
  UPDATE_CONTACT
  WAIT_FOR_REPLY
}

enum FlowExecutionStatus {
  ACTIVE
  COMPLETED
  FAILED
  PAUSED
}

// ============================================================
// CORE: Organization & Users
// ============================================================
//
// M-6: Organization Cascade Audit
// ─────────────────────────────────────────────────────────────
// When an Organization is deleted, the following cascade behavior applies:
//
// CASCADE (deleted with org):
//   User, Contact, ContactNote, ConsentAuditLog, Campaign, DripStep,
//   Segment, Conversation, ConversationNote, WebhookEndpoint,
//   TrackedLink, PhoneNumber, AutoReplyRule, BrandRegistration,
//   CampaignRegistration, MessagingPlan, UsageLedger, AddOnPurchase,
//   BillingAlert, InterestList, ImportJob, ApiKey, P2PAssignment,
//   Subcommunity, Survey, ContentFilter, Flow, MessageBundle
//
// RESTRICT (blocks org deletion if records exist):
//   Message — Messages must be archived/deleted before removing an org.
//             This is intentional: messages are the audit trail and
//             revenue-critical records. Deleting an org with active
//             message history requires explicit cleanup first.
//
// SET NULL (nullifies the FK):
//   ConsentAuditLog.contactId — preserves audit trail after contact deletion
// ─────────────────────────────────────────────────────────────

model Organization {
  id                       String    @id @default(uuid())
  name                     String
  slug                     String    @unique
  timezone                 String    @default("America/New_York")
  quietHoursStart          String    @default("21:00")
  quietHoursEnd            String    @default("08:00")
  politicalDisclaimer      String?
  welcomeMessage           String?   // Message sent to new contacts who opt in
  optOutMessage            String?   // Confirmation message when a contact opts out
  messageSignature         String?   // Optional footer appended to all outbound messages
  accentColor              String?   // UI accent color preference (hex)
  logoUrl                  String?   // Organization logo URL (uploaded via /api/upload)
  orgType                  String    @default("political") // political, government, nonprofit, advocacy
  allowedCampaignTypes     String[]  @default(["BROADCAST", "P2P", "GOTV", "DRIP", "AUTO_REPLY"])
  status                   OrgStatus @default(PENDING_APPROVAL)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  // Relations
  users                    User[]
  contacts                 Contact[]
  campaigns                Campaign[]
  messages                 Message[]
  segments                 Segment[]
  messagingPlan            MessagingPlan?
  usageLedger              UsageLedger[]
  consentAuditLogs         ConsentAuditLog[]
  twilioSubaccount         TwilioSubaccount?
  phoneNumbers             PhoneNumber[]
  brandRegistrations       BrandRegistration[]
  campaignRegistrations    CampaignRegistration[]
  autoReplyRules           AutoReplyRule[]
  conversations            Conversation[]
  importJobs               ImportJob[]
  addOnPurchases           AddOnPurchase[]
  billingAlerts            BillingAlert[]
  quickReplyTemplates      QuickReplyTemplate[]
  dripSteps                DripStep[]
  interestLists            InterestList[]
  messageTemplates         MessageTemplate[]
  trackedLinks             TrackedLink[]
  webhookEndpoints         WebhookEndpoint[]
  apiKeys                  ApiKey[]
  p2pAssignments           P2PAssignment[]
  subcommunities           Subcommunity[]
  surveys                  Survey[]
  contentFilters           ContentFilter[]
  flows                    Flow[]
  messageBundles           MessageBundle[]

  @@index([status])
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  name          String
  orgId         String
  role          UserRole  @default(SENDER)
  isSuperAdmin  Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Two-Factor Authentication (TOTP)
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?   // encrypted TOTP secret
  twoFactorBackupCodes String[] @default([]) // hashed backup codes

  // Auth.js required
  emailVerified DateTime?
  image         String?

  // Relations
  org              Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accounts         Account[]
  sessions         Session[]
  createdCampaigns Campaign[]      @relation("CampaignCreator")
  assignedConversations Conversation[] @relation("ConversationAssignee")
  conversationNotes ConversationNote[]
  contactNotes     ContactNote[]
  createdTemplates MessageTemplate[] @relation("TemplateCreator")
  createdApiKeys   ApiKey[]
  p2pAssignments   P2PAssignment[]
  flows            Flow[]

  @@index([orgId])
  @@index([email])
}

// Auth.js required models
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// CONTACTS & SEGMENTS
// ============================================================

model Contact {
  id              String      @id @default(uuid())
  orgId           String
  phone           String
  prefix          String?  // Mr., Mrs., Dr., etc.
  firstName       String?
  lastName        String?
  suffix          String?  // Jr., Sr., III, etc.
  email           String?
  dateOfBirth     DateTime?
  street          String?
  city            String?
  state           String?
  zip             String?
  precinct        String?
  tags            String[]
  customFields    Json?
  optInStatus     OptInStatus @default(NEVER_OPTED_IN)
  optInSource     String?
  optInTimestamp   DateTime?
  optOutTimestamp  DateTime?
  lastMessageAt   DateTime?
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  org              Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages         Message[]
  consentAuditLogs ConsentAuditLog[]
  conversations    Conversation[]
  contactNotes     ContactNote[]
  interestListMemberships InterestListMember[]
  p2pAssignments   P2PAssignment[]
  subcommunityMembers SubcommunityMember[]
  surveyResponses  SurveyResponse[]
  flowExecutions   FlowExecution[]

  // M-7: Unique constraint moved to a partial index in SQL migration
  // so that soft-deleted contacts (deletedAt IS NOT NULL) don't block
  // re-import of the same phone number. See migration:
  // 20260408_m7_contact_soft_delete_unique
  @@index([orgId, phone])
  @@index([orgId, optInStatus])
  @@index([orgId, createdAt])
  @@index([tags], type: Gin)
  @@index([orgId, precinct])
  @@index([orgId, optInStatus, optOutTimestamp])
}

model ContactNote {
  id        String   @id @default(uuid())
  orgId     String
  contactId String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  // Relations
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
}

model Segment {
  id           String   @id @default(uuid())
  orgId        String
  name         String
  description  String?
  rules        Json     // SegmentRules JSON tree
  contactCount Int      @default(0)
  isArchived   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@index([orgId])
}

model ConsentAuditLog {
  id        String   @id @default(uuid())
  orgId     String
  contactId String?
  action    String   // OPTED_IN, OPTED_OUT, CONSENT_UPDATED, DELETED
  source    String   // csv_import, keyword, web_form, manual, api
  metadata  Json?
  createdAt DateTime @default(now())

  // Relations
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([orgId, contactId])
  @@index([orgId, createdAt])
  @@index([orgId, action, createdAt])
}

// ============================================================
// CAMPAIGNS & MESSAGES
// ============================================================

model Campaign {
  id              String         @id @default(uuid())
  orgId           String
  name            String
  type            CampaignType
  status          CampaignStatus @default(DRAFT)
  messageBody     String
  mediaUrl        String?
  segmentId       String?
  segmentSnapshot Json?          // Frozen contact IDs at launch
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdById     String
  settings        Json?          // Campaign-specific settings

  // Interest list targeting
  interestListMode    String?   // "everyone" | "include" | "exclude" (null = segment only)
  interestListIds     String[]  @default([]) // list IDs to include or exclude

  // P2P-specific fields
  p2pScript           String?   // default script agents see (merge-field template)
  p2pReplyScript      String?   // suggested follow-up for replies
  p2pContactsPerAgent Int?      // contacts assigned per agent batch

  // Counters (denormalized for performance)
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  failedCount     Int @default(0)
  responseCount   Int @default(0)
  optOutCount     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  org             Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  segment         Segment?        @relation(fields: [segmentId], references: [id])
  createdBy       User            @relation("CampaignCreator", fields: [createdById], references: [id])
  messages        Message[]
  dripSteps       DripStep[]
  usageLedger     UsageLedger[]
  trackedLinks    TrackedLink[]
  p2pAssignments  P2PAssignment[]
  surveys         Survey[]

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([orgId, type])
  @@index([orgId, type, status])
}

model DripStep {
  id             String  @id @default(uuid())
  orgId          String
  campaignId     String
  stepOrder      Int
  delayMinutes   Int
  messageBody    String
  mediaUrl       String?
  variantB       String? // A/B test alternate
  splitPercent   Int?    @default(50)

  // Relations
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, stepOrder])
  @@index([orgId])
}

model Message {
  id           String           @id @default(uuid())
  orgId        String
  campaignId   String?
  contactId    String
  direction    MessageDirection
  body         String
  mediaUrl     String?
  twilioSid    String?          @unique
  status       MessageStatus    @default(QUEUED)
  segmentCount Int              @default(1)
  isOverage    Boolean          @default(false)
  cost         Decimal?
  errorCode    String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime         @default(now())

  // Relations — no cascade delete: message logs are retained permanently
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Restrict)
  campaign     Campaign?     @relation(fields: [campaignId], references: [id])
  contact      Contact       @relation(fields: [contactId], references: [id])
  usageLedger  UsageLedger?

  @@index([orgId, createdAt])
  @@index([orgId, campaignId])
  @@index([contactId, createdAt])
  @@index([twilioSid])
  @@index([status])
  @@index([direction])
  @@index([orgId, direction, createdAt])
  @@index([orgId, direction, status, createdAt])
  @@index([campaignId, status])
}

model AutoReplyRule {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  keywords  String[]
  replyBody String
  mediaUrl  String?
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isActive])
}

// ============================================================
// CONVERSATIONS (Inbox)
// ============================================================

model Conversation {
  id           String            @id @default(uuid())
  orgId        String
  contactId    String
  state        ConversationState @default(OPEN)
  assignedToId String?
  isStarred    Boolean           @default(false)
  isEscalated  Boolean           @default(false)
  escalatedReason String?
  escalatedAt  DateTime?
  escalatedById String?
  responseTags String[]          // tags applied to this conversation (e.g., "supportive", "undecided")
  lastMessageAt DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations
  org        Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact    Contact            @relation(fields: [contactId], references: [id])
  assignedTo User?              @relation("ConversationAssignee", fields: [assignedToId], references: [id])
  notes      ConversationNote[]

  @@unique([orgId, contactId])
  @@index([orgId, state])
  @@index([orgId, assignedToId])
  @@index([orgId, lastMessageAt])
  @@index([orgId, isEscalated])
  @@index([orgId, state, assignedToId])
}

model ConversationNote {
  id             String   @id @default(uuid())
  conversationId String
  authorId       String
  body           String
  createdAt      DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model QuickReplyTemplate {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model MessageTemplate {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  category    String   @default("general") // general, gotv, fundraising, event, survey, follow-up
  body        String
  mediaUrl    String?
  language    String   @default("en")
  tags        String[]
  usageCount  Int      @default(0)
  isArchived  Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User         @relation("TemplateCreator", fields: [createdById], references: [id])

  @@index([orgId, category])
  @@index([orgId, isArchived])
}

model TrackedLink {
  id          String   @id @default(uuid())
  orgId       String
  campaignId  String?
  shortCode   String   @unique // unique short code for the link
  originalUrl String
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())

  // Relations
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign Campaign?    @relation(fields: [campaignId], references: [id])
  clicks   LinkClick[]

  @@index([orgId])
  @@index([shortCode])
}

model LinkClick {
  id            String   @id @default(uuid())
  trackedLinkId String
  contactId     String?
  ip            String?
  userAgent     String?
  clickedAt     DateTime @default(now())

  // Relations
  trackedLink TrackedLink @relation(fields: [trackedLinkId], references: [id], onDelete: Cascade)

  @@index([trackedLinkId])
}

model WebhookEndpoint {
  id        String   @id @default(uuid())
  orgId     String
  url       String
  events    String[] // message.sent, message.delivered, message.failed, contact.opted_in, contact.opted_out, campaign.completed
  secret    String   // HMAC signing secret
  isActive  Boolean  @default(true)
  failCount Int      @default(0)
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isActive])
}

// ============================================================
// TWILIO INTEGRATION
// ============================================================

model TwilioSubaccount {
  id                    String  @id @default(uuid())
  orgId                 String  @unique
  accountSid            String
  authTokenEncrypted    String  // AES-256-GCM encrypted
  messagingServiceSid   String?

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model PhoneNumber {
  id           String            @id @default(uuid())
  orgId        String
  twilioSid    String            @unique
  phoneNumber  String            // E.164 format
  capabilities Json?             // voice, sms, mms
  status       PhoneNumberStatus @default(ACTIVE)
  lastChargedAt DateTime?        // last monthly fee charge date
  createdAt    DateTime          @default(now())

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
}

model BrandRegistration {
  id              String                    @id @default(uuid())
  orgId           String
  twilioSid       String?
  brandName       String
  ein             String?
  brandType       String                    // political, government, nonprofit
  address         Json?
  website         String?
  status          BrandRegistrationStatus   @default(PENDING)
  rejectionReason String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  // Relations
  org                   Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaignRegistrations CampaignRegistration[]

  @@index([orgId])
  @@index([orgId, createdAt])
}

model CampaignRegistration {
  id                  String                       @id @default(uuid())
  orgId               String
  brandRegistrationId String
  twilioSid           String?
  useCase             String
  description         String
  sampleMessages      String[]
  messageFlow         String?
  status              CampaignRegistrationStatus   @default(PENDING)
  rejectionReason     String?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  // Relations
  org               Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  brandRegistration BrandRegistration @relation(fields: [brandRegistrationId], references: [id])

  @@index([orgId])
  @@index([orgId, createdAt])
}

// ============================================================
// BILLING & USAGE
// ============================================================

model MessagingPlan {
  id                  String   @id @default(uuid())
  orgId               String   @unique
  balanceCents        Int      @default(0)    // prepaid balance in cents
  smsRateCents        Float    @default(4)    // cost per SMS segment in cents (supports fractional, e.g. 2.37)
  mmsRateCents        Float    @default(8)    // cost per MMS message in cents (supports fractional, e.g. 5.5)
  phoneNumberFeeCents Int      @default(500)  // $5/month per active phone number
  totalSpentCents     Int      @default(0)    // lifetime spend in cents
  stripeCustomerId    String?  @unique
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model UsageLedger {
  id               String   @id @default(uuid())
  orgId            String
  messageId        String   @unique
  campaignId       String?
  segmentCount     Int
  isOverage        Boolean  @default(false)
  twilioCost       Decimal?
  billingCycleStart DateTime
  createdAt        DateTime @default(now())

  // Relations
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  message  Message      @relation(fields: [messageId], references: [id])
  campaign Campaign?    @relation(fields: [campaignId], references: [id])

  @@index([orgId, billingCycleStart])
  @@index([orgId, createdAt])
}

model AddOnPurchase {
  id              String   @id @default(uuid())
  orgId           String
  messageCount    Int
  priceInCents    Int
  stripePaymentId String?
  status          String   @default("pending") // pending, completed, failed
  metadata        Json?    /// Audit metadata: adminUserId, type, timestamp for manual adjustments
  createdAt       DateTime @default(now())

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model BillingAlert {
  id          String   @id @default(uuid())
  orgId       String
  threshold   Int      // 50, 75, 90, 100
  triggeredAt DateTime @default(now())
  notified    Boolean  @default(false)

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// ============================================================
// INTEREST LISTS
// ============================================================

model InterestList {
  id              String   @id @default(uuid())
  orgId           String
  name            String
  keyword         String   // case-insensitive keyword contacts text to join
  description     String?
  welcomeMessage  String?  // auto-reply when someone joins via keyword
  isActive        Boolean  @default(true)
  memberCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  org     Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members InterestListMember[]

  @@unique([orgId, keyword])
  @@index([orgId, isActive])
}

model InterestListMember {
  id             String   @id @default(uuid())
  interestListId String
  contactId      String
  source         String   @default("keyword") // keyword, manual, import
  joinedAt       DateTime @default(now())

  // Relations
  interestList InterestList @relation(fields: [interestListId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([interestListId, contactId])
  @@index([contactId])
}

// ============================================================
// IMPORT JOBS
// ============================================================

model ImportJob {
  id            String   @id @default(uuid())
  orgId         String
  fileName      String
  fileUrl       String?
  fileSize      Int?
  totalRows     Int      @default(0)
  processedRows Int      @default(0)
  successRows   Int      @default(0)
  errorRows     Int      @default(0)
  columnMapping Json?
  consentSource String?
  status        String   @default("pending") // pending, processing, completed, failed
  errorLog      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, createdAt])
}

// ============================================================
// API KEYS
// ============================================================

model ApiKey {
  id          String    @id @default(uuid())
  orgId       String
  name        String
  keyHash     String    @unique // SHA-256 hash of the key (never store plaintext)
  keyPrefix   String    // First 8 chars for identification (e.g., "ct_live_ab")
  permissions String[]  // e.g., ["contacts:read", "contacts:write", "messages:send"]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User         @relation(fields: [createdById], references: [id])

  @@index([orgId])
  @@index([keyHash])
}

// ============================================================
// P2P ASSIGNMENTS
// ============================================================

model P2PAssignment {
  id            String              @id @default(uuid())
  orgId         String
  campaignId    String
  contactId     String
  assignedToId  String
  status        P2PAssignmentStatus @default(PENDING)
  sentAt        DateTime?
  skippedAt     DateTime?
  skippedReason String?
  customBody    String?             // agent's modified version of the script, if any
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  // Relations
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign   Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo User         @relation(fields: [assignedToId], references: [id])

  @@unique([campaignId, contactId])
  @@index([campaignId, assignedToId, status])
  @@index([orgId])
}

// ============================================================
// SUBCOMMUNITIES
// ============================================================

model Subcommunity {
  id            String                  @id @default(uuid())
  orgId         String
  org           Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  imageUrl      String?
  joinKeyword   String?
  isPublic      Boolean                 @default(true)
  memberCount   Int                     @default(0)
  members       SubcommunityMember[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@unique([orgId, name])
  @@unique([orgId, joinKeyword])
  @@index([orgId])
}

model SubcommunityMember {
  id              String        @id @default(uuid())
  subcommunityId  String
  subcommunity    Subcommunity  @relation(fields: [subcommunityId], references: [id], onDelete: Cascade)
  contactId       String
  contact         Contact       @relation(fields: [contactId], references: [id])
  joinedAt        DateTime      @default(now())
  source          String?

  @@unique([subcommunityId, contactId])
  @@index([subcommunityId])
  @@index([contactId])
}

// ============================================================
// PLATFORM SETTINGS (admin-configurable key-value store)
// ============================================================

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ============================================================
// SURVEYS
// ============================================================

model Survey {
  id          String           @id @default(uuid())
  orgId       String
  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaignId  String?
  campaign    Campaign?        @relation(fields: [campaignId], references: [id])
  name        String
  question    String
  type        SurveyType       @default(MULTIPLE_CHOICE)
  options     Json             @default("[]")
  allowOther  Boolean          @default(false)
  status      SurveyStatus     @default(DRAFT)
  responses   SurveyResponse[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([orgId])
  @@index([campaignId])
}

model SurveyResponse {
  id          String   @id @default(uuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id])
  answer      String
  rawMessage  String?
  respondedAt DateTime @default(now())

  @@unique([surveyId, contactId])
  @@index([surveyId])
}

// ============================================================
// CONTENT FILTERS
// ============================================================

model ContentFilter {
  id        String              @id @default(uuid())
  orgId     String
  org       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  phrase    String
  action    ContentFilterAction  @default(HIDE)
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())

  @@unique([orgId, phrase])
  @@index([orgId])
}

// ============================================================
// FLOWS (Automation)
// ============================================================

model Flow {
  id            String       @id @default(uuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  status        FlowStatus   @default(DRAFT)
  trigger       FlowTrigger
  triggerConfig Json         @default("{}")
  createdById   String
  createdBy     User         @relation(fields: [createdById], references: [id])
  steps         FlowStep[]
  executions    FlowExecution[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([orgId])
  @@index([orgId, status])
}

model FlowStep {
  id            String       @id @default(uuid())
  flowId        String
  flow          Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  type          FlowStepType
  config        Json         @default("{}")
  position      Int          @default(0)
  parentStepId  String?
  parentStep    FlowStep?    @relation("StepChildren", fields: [parentStepId], references: [id], onDelete: SetNull)
  children      FlowStep[]   @relation("StepChildren")
  yesStepId     String?      @unique
  noStepId      String?      @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([flowId])
}

model FlowExecution {
  id            String              @id @default(uuid())
  flowId        String
  flow          Flow                @relation(fields: [flowId], references: [id])
  contactId     String
  contact       Contact             @relation(fields: [contactId], references: [id])
  status        FlowExecutionStatus @default(ACTIVE)
  currentStepId String?
  startedAt     DateTime            @default(now())
  completedAt   DateTime?
  data          Json                @default("{}")

  @@index([flowId])
  @@index([contactId])
  @@index([flowId, status])
}

// ============================================================
// MESSAGE BUNDLES (Pre-Purchase)
// ============================================================

model MessageBundle {
  id              String    @id @default(uuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bundleName      String
  messageCount    Int
  pricePerMessage Float
  totalPrice      Float
  purchasedAt     DateTime  @default(now())
  expiresAt       DateTime?
  remaining       Int
  stripePaymentId String?

  @@index([orgId])
}

# ===========================================
# CivicText Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://civictext:civictext_dev@localhost:5432/civictext?schema=public"

# Redis (local dev)
REDIS_URL="redis://localhost:6379"

# Redis (production - Upstash)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Auth (NextAuth.js v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL=http://localhost:3000

# Google OAuth (optional)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Microsoft OAuth (optional)
# AUTH_MICROSOFT_ENTRA_ID_ID=
# AUTH_MICROSOFT_ENTRA_ID_SECRET=

# Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WEBHOOK_SECRET=

# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_STARTER_PRICE_ID=
# STRIPE_GROWTH_PRICE_ID=
# STRIPE_PROFESSIONAL_PRICE_ID=
# STRIPE_ENTERPRISE_PRICE_ID=

# File Storage (S3 / Cloudflare R2)
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# Email (Resend)
# RESEND_API_KEY=
# EMAIL_FROM=noreply@civictext.com

# Monitoring (Sentry)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# OpenAI (AI message generation)
# OPENAI_API_KEY=

# Encryption (for Twilio auth tokens at rest)
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=
